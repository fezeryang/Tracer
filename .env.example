# Market Data API Keys
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
EIA_API_KEY=

# Gemini API Key
GEMINI_API_KEY=
VITE_GEMINI_API_KEY=

# SEC EDGAR
SEC_USER_AGENT=

# DeepSeek official source authority review and report engine (server-side only)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Market Data - Massive / Polygon compatible
# MASSIVE_API_KEY is preferred.
# MASSIVE_BASE_URL defaults to https://api.massive.com.
# POLYGON_KEY is kept for legacy compatibility.
# If both are present, MASSIVE_API_KEY is used first.
# Do not expose market data keys to frontend.
MASSIVE_API_KEY=
MASSIVE_BASE_URL=https://api.massive.com
POLYGON_KEY=

# Existing keys (optional, can be moved to env)
FINNHUB_KEY=

# RapidAPI (Insider Trading API + StockTwits social sentiment)
RAPIDAPI_KEY=
STOCKTWITS_RAPIDAPI_HOST=stocktwits.p.rapidapi.com
